{
  "_version": "1.81.0",
  "sap.app": {
    "id": "claro.com.clarocomprobantes",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.1",
      "toolsId": "652dd905-64eb-45a4-a470-09b0b3438e30"
    },
    "crossNavigation": {
      "inbounds": {
        "Comprobante-create": {
          "semanticObject": "Comprobante",
          "action": "create",
          "title": "{{Comprobante-create.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.144.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.ui.layout": {},
        "sap.ui.unified": {},
        "sap.uxap": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "claro.com.clarocomprobantes.i18n.i18n"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "claro.com.clarocomprobantes.view",
        "async": true,
        "viewPath": "claro.com.clarocomprobantes.view"
      },
      "routes": [
        {
          "name": "RouteRegisterVoucher",
          "pattern": "",
          "target": ["TargetRegisterVoucher"]
        },
        {
          "name": "RouteDocumentList",
          "pattern": "documents",
          "target": ["TargetDocumentList"]
        },
        {
          "name": "RouteDocumentDetail",
          "pattern": "documents/{tipoDocumento}/{numeroDocumento}/{documentId}",
          "target": ["TargetDocumentDetail"]
        },
        {
          "name": "RouteRegisterVoucherForDoc",
          "pattern": "register/{tipoDocumento}/{numeroDocumento}/{documentId}",
          "target": ["TargetRegisterVoucher"]
        },
        {
          "name": "RouteVoucherDetail",
          "pattern": "voucher/{tipoDocumento}/{numeroDocumento}/{documentId}/{comprobanteId}/{mode}",
          "target": ["TargetRegisterVoucher"]
        },
        {
          "name": "RouteVoucherList",
          "pattern": "vouchers",
          "target": ["TargetVoucherList"]
        }
      ],
      "targets": {
        "TargetDocumentList": {
          "id": "DocumentList",
          "name": "DocumentList"
        },
        "TargetDocumentDetail": {
          "id": "DocumentDetail",
          "name": "DocumentDetail"
        },
        "TargetRegisterVoucher": {
          "id": "RegisterVoucher",
          "name": "RegisterVoucher"
        },
        "TargetVoucherList": {
          "id": "VoucherList",
          "name": "VoucherList"
        }
      }
    },
    "rootView": {
      "viewName": "claro.com.clarocomprobantes.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "clarocomclarocomprobantes"
  }
}
